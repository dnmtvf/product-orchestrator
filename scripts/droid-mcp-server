#!/opt/homebrew/bin/bash
# Droid MCP Server Wrapper
# Uses MCP protocol version 2024-11-05 (official spec)

# Note: set -e is intentionally NOT used. The MCP server loop must survive
# individual tool call errors without crashing the entire server process.

# Session storage (in-memory associative array; requires Bash 4+)
declare -A SESSIONS

# Generate session ID
generate_session_id() {
    echo "session-$(date +%s)-$RANDOM"
}

# Run droid task and return JSON
run_droid_task() {
    local prompt="$1"
    local repo_path="${2:-.}"
    local model="${3:-MiniMax-M2.5}"
    local auto_level="${4:-high}"

    local session_id
    session_id=$(generate_session_id)

    local output
    # Use env to pass variables to avoid complex quoting
    output=$(env DROID_PROMPT="$prompt" DROID_REPO="$repo_path" DROID_MODEL="$model" DROID_AUTO="$auto_level" bash -c 'droid exec -m "$DROID_MODEL" --auto "$DROID_AUTO" -o json --cwd "$DROID_REPO" "$DROID_PROMPT"')

    SESSIONS["$session_id"]="$output"

    local result_content
    local droid_session_id
    local is_error

    result_content=$(echo "$output" | jq -r '.result // ""' 2>/dev/null || echo "")
    droid_session_id=$(echo "$output" | jq -r '.session_id // ""' 2>/dev/null || echo "")
    is_error=$(echo "$output" | jq -r '.is_error // false' 2>/dev/null || echo "false")

    jq -n \
        --arg session_id "$session_id" \
        --arg droid_session_id "$droid_session_id" \
        --arg status "$([[ "$is_error" == "true" ]] && echo "error" || echo "completed")" \
        --arg result "$result_content" \
        --arg full_output "$output" \
        '{session_id: $session_id, droid_session_id: $droid_session_id, status: $status, result: $result, full_output: $full_output}'
}

# Continue a session
continue_session() {
    local session_id="$1"
    local prompt="$2"

    if [[ -z "${SESSIONS[$session_id]+x}" ]]; then
        jq -n --arg id "$session_id" '{"error": ("Session not found: " + $id)}'
        return 0
    fi

    local previous_output="${SESSIONS[$session_id]}"
    local previous_result
    previous_result=$(echo "$previous_output" | jq -r '.result // ""' 2>/dev/null || echo "")
    local new_prompt="$prompt\n\nPrevious context: $previous_result"

    local output
    output=$(env DROID_PROMPT="$new_prompt" bash -c 'droid exec -m MiniMax-M2.5 --auto high -o json --cwd . "$DROID_PROMPT"')

    SESSIONS["$session_id"]="$output"

    local result_content
    local is_error

    result_content=$(echo "$output" | jq -r '.result // ""' 2>/dev/null || echo "")
    is_error=$(echo "$output" | jq -r '.is_error // false' 2>/dev/null || echo "false")

    jq -n \
        --arg session_id "$session_id" \
        --arg status "$([[ "$is_error" == "true" ]] && echo "error" || echo "completed")" \
        --arg result "$result_content" \
        --arg full_output "$output" \
        '{session_id: $session_id, status: $status, result: $result, full_output: $full_output}'
}

# Get session result
get_session_result() {
    local session_id="$1"

    if [[ -z "${SESSIONS[$session_id]+x}" ]]; then
        jq -n --arg id "$session_id" '{"error": ("Session not found: " + $id)}'
        return 0
    fi

    echo "${SESSIONS[$session_id]}"
}

# MCP server main loop
mcp_server() {
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        local method
        local id

        method=$(echo "$line" | jq -r '.method // empty' 2>/dev/null)
        id=$(echo "$line" | jq -r '.id // empty' 2>/dev/null)

        case "$method" in
            "initialize")
                jq -n \
                    --arg id "${id:-null}" \
                    '{"jsonrpc":"2.0","id":($id | tonumber? // null),"result":{"protocolVersion":"2024-11-05","capabilities":{"tools":{}},"serverInfo":{"name":"droid-worker","version":"1.0.0"}}}'
                ;;
            "tools/list")
                jq -n \
                    --arg id "${id:-null}" \
                    '{"jsonrpc":"2.0","id":($id | tonumber? // null),"result":{"tools":[{"name":"droid_run_task","description":"Run a task using Droid CLI with MiniMax-M2.5","inputSchema":{"type":"object","properties":{"prompt":{"type":"string","description":"Task prompt for the worker"},"repo_path":{"type":"string","description":"Repository path (default: .)"},"model":{"type":"string","description":"Model to use (default: MiniMax-M2.5)"},"auto_level":{"type":"string","description":"Autonomy level (default: high)"}},"required":["prompt"]}},{"name":"droid_continue","description":"Continue a session with additional prompt","inputSchema":{"type":"object","properties":{"session_id":{"type":"string"},"prompt":{"type":"string"}},"required":["session_id","prompt"]}},{"name":"droid_get_result","description":"Get the result of a previous session","inputSchema":{"type":"object","properties":{"session_id":{"type":"string"}},"required":["session_id"]}}]}}'
                ;;
            "tools/call")
                local tool_name
                tool_name=$(echo "$line" | jq -r '.params.name // empty')

                case "$tool_name" in
                    "droid_run_task")
                        local prompt repo_path model auto_level
                        prompt=$(echo "$line" | jq -r '.params.arguments.prompt // ""')
                        repo_path=$(echo "$line" | jq -r '.params.arguments.repo_path // "."')
                        model=$(echo "$line" | jq -r '.params.arguments.model // "MiniMax-M2.5"')
                        auto_level=$(echo "$line" | jq -r '.params.arguments.auto_level // "high"')

                        local result
                        result=$(run_droid_task "$prompt" "$repo_path" "$model" "$auto_level")
                        jq -n \
                            --arg id "${id:-null}" \
                            --arg result "$result" \
                            '{"jsonrpc":"2.0","id":($id | tonumber? // null),"result":{"content":[{"type":"text","text":$result}]}}'
                        ;;
                    "droid_continue")
                        local session_id prompt
                        session_id=$(echo "$line" | jq -r '.params.arguments.session_id // ""')
                        prompt=$(echo "$line" | jq -r '.params.arguments.prompt // ""')

                        local result
                        result=$(continue_session "$session_id" "$prompt")
                        jq -n \
                            --arg id "${id:-null}" \
                            --arg result "$result" \
                            '{"jsonrpc":"2.0","id":($id | tonumber? // null),"result":{"content":[{"type":"text","text":$result}]}}'
                        ;;
                    "droid_get_result")
                        local session_id
                        session_id=$(echo "$line" | jq -r '.params.arguments.session_id // ""')

                        local result
                        result=$(get_session_result "$session_id")
                        jq -n \
                            --arg id "${id:-null}" \
                            --arg result "$result" \
                            '{"jsonrpc":"2.0","id":($id | tonumber? // null),"result":{"content":[{"type":"text","text":$result}]}}'
                        ;;
                    *)
                        jq -n --arg id "${id:-null}" --arg name "$tool_name" \
                            '{"jsonrpc":"2.0","id":($id | tonumber? // null),"error":{"code":-32601,"message":("Unknown tool: " + $name)}}'
                        ;;
                esac
                ;;
            "notifications/initialized")
                # No response required
                ;;
            *)
                jq -n --arg id "${id:-null}" \
                    '{"jsonrpc":"2.0","id":($id | tonumber? // null),"error":{"code":-32600,"message":"Invalid request"}}'
                ;;
        esac
    done
}

# Check if running as MCP server or direct command
if [[ "$1" == "--mcp" ]] || [[ ! -t 0 && -z "$1" ]]; then
    mcp_server
else
    case "${1:-}" in
        run)
            run_droid_task "$2" "${3:-.}" "${4:-MiniMax-M2.5}" "${5:-high}"
            ;;
        continue)
            continue_session "$2" "$3"
            ;;
        result)
            get_session_result "$2"
            ;;
        *)
            echo "Usage: $0 <run|continue|result> [args...]"
            echo "       $0 --mcp  # Run as MCP server"
            exit 1
            ;;
    esac
fi
